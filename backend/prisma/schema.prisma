generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String  @id
  name               String
  email              String  @unique
  phone              String?
  role               String  // manager | supervisor | admin
  avatarUrl          String?
  isActive           Boolean @default(true)
  passwordHash       String  @default("")
  mustChangePassword Boolean @default(false)
  createdAt          String
  lastLoginAt        String?
  supervisorId       String?

  // Gmail OAuth 2.0
  gmailRefreshToken String?
  gmailAccessToken  String?
  gmailTokenExpiry  String?
  gmailEmail        String?
  gmailWatchExpiry  String?
  gmailHistoryId    String?

  supervisor       User?              @relation("UserSupervisor", fields: [supervisorId], references: [id])
  reports          User[]             @relation("UserSupervisor")
  clients          Client[]           @relation("ClientManager")
  deals            Deal[]             @relation("DealManager")
  activities       Activity[]         @relation("ActivityManager")
  assignedTasks    Task[]             @relation("TaskAssignee")
  statusChanges    DealStatusChange[] @relation("StatusChanger")
  assignedRequests Request[]          @relation("RequestAssignee")
  emailThreads     EmailThread[]      @relation("ThreadManager")
  sentEmails       EmailMessage[]     @relation("SentByUser")
}

model Company {
  id        String  @id
  name      String
  inn       String?
  address   String?
  phone     String?
  createdAt String

  clients Client[] @relation("ClientCompany")
  deals   Deal[]   @relation("DealCompany")
}

model Client {
  id            String  @id
  firstName     String
  lastName      String
  middleName    String?
  company       String? // legacy plain text, kept for backwards compat
  companyId     String? // FK → Company
  email         String?
  phone         String?
  address       String?
  position      String? // должность контакта
  status        String  // lead | active | regular | archived
  managerId     String
  tags          String  @default("[]") // JSON array stored as string
  source        String?
  comment       String?
  createdAt     String
  lastContactAt String?

  manager      User          @relation("ClientManager", fields: [managerId], references: [id])
  companyRef   Company?      @relation("ClientCompany", fields: [companyId], references: [id])
  deals        Deal[]        @relation("DealClient")
  activities   Activity[]    @relation("ActivityClient")
  tasks        Task[]        @relation("TaskClient")
  requests     Request[]     @relation("RequestContact")
  emailThreads EmailThread[] @relation("ThreadClient")
}

model Deal {
  id          String  @id
  title       String
  clientId    String
  companyId   String? // FK → Company (опционально)
  managerId   String
  status      String  // new | negotiation | proposal_sent | awaiting_payment | won | lost
  amount      Float
  deadline    String?
  description String?
  createdAt   String
  updatedAt   String

  client        Client             @relation("DealClient", fields: [clientId], references: [id])
  companyRef    Company?           @relation("DealCompany", fields: [companyId], references: [id])
  manager       User               @relation("DealManager", fields: [managerId], references: [id])
  statusChanges DealStatusChange[] @relation("StatusChangeDeal")
  activities    Activity[]         @relation("ActivityDeal")
  tasks         Task[]             @relation("TaskDeal")
  requests      Request[]          @relation("RequestDeal")
  emailThreads  EmailThread[]      @relation("ThreadDeal")
}

model Request {
  id          String  @id
  title       String
  description String?
  status      String  @default("new") // new | in_progress | resolved | closed
  contactId   String?
  dealId      String?
  assigneeId  String?
  createdAt   String
  closedAt    String?

  contact  Client? @relation("RequestContact", fields: [contactId], references: [id])
  deal     Deal?   @relation("RequestDeal", fields: [dealId], references: [id])
  assignee User?   @relation("RequestAssignee", fields: [assigneeId], references: [id])
}

model DealStatusChange {
  id         String  @id
  dealId     String
  fromStatus String?
  toStatus   String
  changedBy  String
  changedAt  String

  deal    Deal @relation("StatusChangeDeal", fields: [dealId], references: [id])
  changer User @relation("StatusChanger", fields: [changedBy], references: [id])
}

model Activity {
  id          String  @id
  type        String  // call | email | meeting | note | status_change
  managerId   String
  clientId    String?
  dealId      String?
  date        String
  description String
  result      String?
  createdAt   String

  manager User    @relation("ActivityManager", fields: [managerId], references: [id])
  client  Client? @relation("ActivityClient", fields: [clientId], references: [id])
  deal    Deal?   @relation("ActivityDeal", fields: [dealId], references: [id])
}

model Task {
  id          String   @id
  title       String
  description String?
  status      String   // new | in_progress | done
  priority    String   // low | medium | high
  assigneeId  String
  clientId    String?
  dealId      String?
  deadline    String?
  createdAt   String
  completedAt String?
  isArchived  Boolean  @default(false)
  archivedAt  String?

  assignee User    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  client   Client? @relation("TaskClient", fields: [clientId], references: [id])
  deal     Deal?   @relation("TaskDeal", fields: [dealId], references: [id])
}

model EmailThread {
  id            String  @id
  gmailThreadId String  @unique
  subject       String
  clientId      String?
  dealId        String?
  managerId     String
  lastMessageAt String
  snippet       String?
  createdAt     String

  manager  User           @relation("ThreadManager", fields: [managerId], references: [id])
  client   Client?        @relation("ThreadClient", fields: [clientId], references: [id])
  deal     Deal?          @relation("ThreadDeal", fields: [dealId], references: [id])
  messages EmailMessage[] @relation("ThreadMessages")
}

model EmailMessage {
  id             String  @id
  gmailMessageId String  @unique
  threadId       String
  fromAddress    String
  toAddress      String
  subject        String
  bodyText       String?
  direction      String          // outbound | inbound
  sentAt         String
  deliveryStatus String  @default("sent")
  sentByUserId   String?
  createdAt      String

  thread  EmailThread @relation("ThreadMessages", fields: [threadId], references: [id])
  sentBy  User?       @relation("SentByUser", fields: [sentByUserId], references: [id])
}
