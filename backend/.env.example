# SQLite database file path (relative to backend/ directory)
DATABASE_URL="file:./prisma/dev.db"

# JWT secret key — ОБЯЗАТЕЛЬНО замените на случайную строку перед деплоем
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# HTTP port for the Express server
PORT=3001

# bcrypt rounds (10 is recommended; higher = slower but more secure)
BCRYPT_ROUNDS=10

# ─── Gmail OAuth 2.0 ─────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# 1. Enable "Gmail API" in GCP Console
# 2. Create OAuth 2.0 Client ID (Web application type)
# 3. Add GOOGLE_REDIRECT_URI to "Authorized redirect URIs"
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/email/auth/callback

# ─── Google Cloud Pub/Sub (for Gmail push notifications / webhooks) ───────────
# 1. Enable "Cloud Pub/Sub API" in GCP Console
# 2. Create a Topic named "gmail-push"
# 3. Create a Push Subscription pointing to:
#    https://your-domain.com/api/email/webhook?token=<PUBSUB_VERIFICATION_TOKEN>
# 4. Grant "gmail-api-push@system.gserviceaccount.com" the "Pub/Sub Publisher" role on the topic
# For local dev: use ngrok to expose localhost and update this URI
PUBSUB_TOPIC_NAME=projects/your-gcp-project-id/topics/gmail-push
PUBSUB_VERIFICATION_TOKEN=change_this_to_a_random_secret_string

# ─── VK OAuth 2.0 ────────────────────────────────────────────────────────────
# Get from: https://vk.com/editapp → Настройки
# IMPORTANT: VK requires HTTPS redirect URIs. Use ngrok for local dev:
#   1. Install: npm install -g ngrok  (or download from https://ngrok.com/download)
#   2. Run: ngrok http 3001
#   3. Use the generated https://xxxx-xxx.ngrok-free.app URL below
#   4. In VK app settings add both URIs to "Доверенные redirect URI"
VK_CLIENT_ID=your_vk_app_id
VK_CLIENT_SECRET=your_vk_secure_key
VK_REDIRECT_URI_LOGIN=https://xxxx-xxx.ngrok-free.app/api/auth/vk/callback
VK_REDIRECT_URI_LINK=https://xxxx-xxx.ngrok-free.app/api/vk/link/callback

# ─── Frontend URL (used for OAuth callback redirect) ─────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── CORS (comma-separated list of allowed origins) ──────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
