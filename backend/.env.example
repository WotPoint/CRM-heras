# SQLite database file path (relative to backend/ directory)
DATABASE_URL="file:./prisma/dev.db"

# JWT secret key — change this to a long random string (32+ chars) in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secret-key-here"

# HTTP port for the Express server
PORT=3001

# bcrypt rounds (10 is recommended; higher = slower but more secure)
BCRYPT_ROUNDS=10
